# ============================================================
# SentinelOps — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
#
# Quick Start (Demo Mode - No Splunk Needed):
#   cp .env.example .env
#   python -m backend.main
# ============================================================

# --- Application Settings ---
DEMO_MODE=true                # true = pre-baked responses (no Splunk needed)
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
LOG_LEVEL=INFO

# --- Splunk MCP Server Connection ---
SPLUNK_HOST=https://localhost
SPLUNK_PORT=8089
SPLUNK_TOKEN=your-splunk-mcp-token-here
SPLUNK_MCP_MODE=sse           # sse | stdio | api
SPLUNK_INDEX=sentinalops_os   # Default index for SentinelOps data
SPLUNK_VERIFY_SSL=false       # Set to true in production

# --- LLM Configuration ---
LLM_PROVIDER=gemini           # openai | gemini | ollama
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=gemini-2.0-flash    # Model identifier
LLM_TEMPERATURE=0.1           # Low temperature for deterministic agent reasoning
LLM_MAX_TOKENS=4096

# --- Optional: Splunk AI Assistant ---
SPLUNK_AI_ASSISTANT_ENABLED=false

# --- Optional: Splunk SOAR ---
SOAR_ENABLED=false
SOAR_HOST=https://localhost
SOAR_TOKEN=your-soar-token-here
